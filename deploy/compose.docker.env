# Docker Compose 默认环境（容器内网络与常用默认值）
# 生产环境请通过同目录下的 .env 覆盖敏感项（Compose 会自动读取 .env 做变量替换）

PORT=8080
LOG_LEVEL=info
READ_TIMEOUT=10
WRITE_TIMEOUT=10
SHUTDOWN_TIMEOUT=5
DEBUG=false
VERSION=1.0.0

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=devops_local_root
MYSQL_DATABASE=devops
MYSQL_MAX_IDLE_CONNS=10
MYSQL_MAX_OPEN_CONNS=100
MYSQL_CONN_MAX_LIFETIME=3600

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

K8S_KUBECONFIG_PATH=
# Docker 内访问宿主机 kind/minikube：将 kubeconfig 里 127.0.0.1/localhost 的 API 地址重写为该主机名（Linux 需 compose extra_hosts）
K8S_API_SERVER_HOST_REWRITE=host.docker.internal
K8S_NAMESPACE=default
K8S_CHECK_TIMEOUT=300
# 制品库 / OCI Registry：与 deploy/docker-compose.yaml 中 registry 服务对应
#   - 在 devops 容器内应使用 compose 注入的 K8S_REGISTRY（默认 registry:5000，见 devops.environment）
#   - 宿主机 docker push / 浏览器：http://localhost:5001
K8S_REGISTRY=registry:5000
K8S_REPOSITORY=jeridevops

# Builder Pod 默认配置；后台“构建 Pod 管理”保存后会持久化覆盖这些默认值
PIPELINE_BUILDER_IDLE_TIMEOUT_MINUTES=30
PIPELINE_BUILDER_STORAGE_TYPE=hostpath
PIPELINE_BUILDER_PVC_NAME=devops-workspace-shared
PIPELINE_BUILDER_PVC_SIZE_GI=10
PIPELINE_BUILDER_STORAGE_CLASS=
PIPELINE_BUILDER_ACCESS_MODE=ReadWriteOnce
PIPELINE_BUILDER_HOST_PATH=/tmp/devops-workspace
PIPELINE_BUILDER_CPU_REQUEST=100m
PIPELINE_BUILDER_CPU_LIMIT=2
PIPELINE_BUILDER_MEMORY_REQUEST=128Mi
PIPELINE_BUILDER_MEMORY_LIMIT=1Gi

JWT_SECRET=devops-local-change-me
JWT_EXPIRATION=24

# GitLab/GitHub/Gitee Webhook 回调基地址；Docker Compose 本地联调默认走容器内网络
WEBHOOK_BASE_URL=http://devops
