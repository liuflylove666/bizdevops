# Server Configuration
PORT=8080
LOG_LEVEL=info
READ_TIMEOUT=10
WRITE_TIMEOUT=10
SHUTDOWN_TIMEOUT=5
DEBUG=false
VERSION=1.0.0

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=devops
MYSQL_MAX_IDLE_CONNS=10
MYSQL_MAX_OPEN_CONNS=100
MYSQL_CONN_MAX_LIFETIME=3600

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# K8s Configuration
K8S_KUBECONFIG_PATH=
# 本机 go run 直连 kind 时不要设置；Docker 内连宿主机 kind 时可设为 host.docker.internal（见 README）
# K8S_API_SERVER_HOST_REWRITE=host.docker.internal
K8S_NAMESPACE=default
K8S_CHECK_TIMEOUT=300
K8S_REGISTRY=
K8S_REPOSITORY=

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24
